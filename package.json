{
  "name": "care-law",
  "private": true,
  "version": "0.1.0",
  "description": "케어로 — 화이트레이블 가맹점주 법률 케어 서비스",
  "scripts": {
    "dev":             "npx pnpm --parallel --filter './apps/*' dev",
    "dev:admin":       "npx pnpm --filter admin dev",
    "dev:franchisor":  "npx pnpm --filter franchisor dev",
    "dev:franchisee":  "npx pnpm --filter franchisee dev",
    "dev:all":         "npx pnpm --parallel --filter './apps/*' dev",
    "build:all":       "npx pnpm --filter './apps/*' build",
    "build:functions": "npx pnpm --filter functions build",
    "type-check":      "npx pnpm --filter './apps/*' type-check"
  },
  "engines": { "node": ">=20", "pnpm": ">=9" }
}
